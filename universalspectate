	DisplayName.Size = UDim2.new(1, 0, 0, 22)
	DisplayName.Position = UDim2.new(0, 0, 0.5, -22)
	DisplayName.BackgroundTransparency = 1
	DisplayName.Text = player.DisplayName
	DisplayName.TextXAlignment = Enum.TextXAlignment.Left
	DisplayName.TextTruncate = Enum.TextTruncate.AtEnd
	DisplayName.Parent = NameBlock
	style(DisplayName, 13, true)

	local UserName = Instance.new("TextLabel")
	UserName.Size = UDim2.new(1, 0, 0, 18)
	UserName.Position = UDim2.new(0, 0, 0.5, 2)
	UserName.BackgroundTransparency = 1
	UserName.Text = "(" .. player.Name .. ")"
	UserName.TextXAlignment = Enum.TextXAlignment.Left
	UserName.TextTruncate = Enum.TextTruncate.AtEnd
	UserName.Parent = NameBlock
	style(UserName, 11, false, true)

	if player ~= LocalPlayer then
		local SpectateBtn = Instance.new("TextButton")
		SpectateBtn.Name = "SpectateBtn"
		SpectateBtn.Size = UDim2.new(0, 70, 0, 28)
		SpectateBtn.Position = UDim2.new(1, -78, 0.5, -14)
		SpectateBtn.BackgroundColor3 = COLORS.spectate
		SpectateBtn.BorderSizePixel = 0
		SpectateBtn.Text = "Spectate"
		SpectateBtn.Parent = Card
		style(SpectateBtn, 11, false)

		local specCorner = Instance.new("UICorner")
		specCorner.CornerRadius = UDim.new(0, 6)
		specCorner.Parent = SpectateBtn

		SpectateBtn.MouseEnter:Connect(function()
			TweenService:Create(SpectateBtn, TweenInfo.new(0.15), {BackgroundColor3 = COLORS.spectateAct}):Play()
		end)
		SpectateBtn.MouseLeave:Connect(function()
			local col = (spectateTarget == player) and COLORS.spectateAct or COLORS.spectate
			TweenService:Create(SpectateBtn, TweenInfo.new(0.15), {BackgroundColor3 = col}):Play()
		end)
		SpectateBtn.MouseButton1Click:Connect(function()
			if freecamActive then stopFreecam() end
			startSpectating(player)
			for _, card in pairs(cardCache) do
				local btn = card:FindFirstChild("SpectateBtn")
				if btn then btn.BackgroundColor3 = COLORS.spectate; btn.Text = "Spectate" end
			end
			if spectating and spectateTarget == player then
				SpectateBtn.BackgroundColor3 = COLORS.spectateAct
				SpectateBtn.Text = "Stop"
			end
		end)
	end

	cardCache[player.UserId] = Card
end

local function removeCard(player)
	if cardCache[player.UserId] then
		cardCache[player.UserId]:Destroy()
		cardCache[player.UserId] = nil
	end
	if spectateTarget == player then stopSpectating() end
end

for _, player in ipairs(Players:GetPlayers()) do makeCard(player) end
Players.PlayerAdded:Connect(makeCard)
Players.PlayerRemoving:Connect(removeCard)

local dragging = false
local dragStart = nil
local startPos = nil

Header.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = Panel.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		Panel.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end
end)
