--=========================================================
-- STOP SPECTATE
--=========================================================
local function stopSpectating()
    if spectateConn then spectateConn:Disconnect(); spectateConn = nil end
    if fpRenderConn then fpRenderConn:Disconnect(); fpRenderConn = nil end

    local prevTarget = spectateTarget
    clearHighlight()

    UIS.MouseBehavior = Enum.MouseBehavior.Default
    UIS.MouseIconEnabled = true
    KeybindFrame.Visible = false

    spectating = false
    spectateTarget = nil
    Camera.CameraType = Enum.CameraType.Custom

    local char = LocalPlayer.Character
    if char then
        Camera.CameraSubject = char:FindFirstChildOfClass("Humanoid") or char:FindFirstChild("HumanoidRootPart")
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.LocalTransparencyModifier = 0 end
        end
    end

    if prevTarget and prevTarget.Character then
        for _, part in ipairs(prevTarget.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.LocalTransparencyModifier = 0 end
        end
    end

    updateCardVisuals()
    updateSpectateBar()
    updateStatus("Ready")
end

--=========================================================
-- START SPECTATE
--=========================================================
local function startSpectating(player, mode)
    if spectating and spectateTarget == player and spectateMode == mode then
        stopSpectating()
        return
    end

    stopSpectating()
    spectating = true
    spectateTarget = player
    spectateMode = mode

    if mode == "3rd" then
        local function attach()
            local char = player.Character
            if not char then return end
            Camera.CameraType = Enum.CameraType.Custom
            Camera.CameraSubject = char:FindFirstChildOfClass("Humanoid") or char:FindFirstChild("HumanoidRootPart")
            applyHighlight(char)
        end
        attach()
        spectateConn = player.CharacterAdded:Connect(function()
            task.wait(0.1)
            if spectateTarget == player then attach() end
        end)
    else
        clearHighlight()
        Camera.CameraType = Enum.CameraType.Scriptable
        KeybindFrame.Visible = true

        local rx, ry = Camera.CFrame:ToEulerAnglesYXZ()
        fpPitch, fpYaw = rx, ry

        task.defer(function()
            UIS.MouseBehavior = Enum.MouseBehavior.LockCenter
            UIS.MouseIconEnabled = false
        end)

        fpRenderConn = RunService.RenderStepped:Connect(function()
            if not spectating or spectateTarget ~= player then return end
            local char = player.Character
            local head = char and char:FindFirstChild("Head")
            if head then
                local delta = UIS:GetMouseDelta()
                fpYaw = fpYaw - delta.X * FREECAM_SENS * 0.022
                fpPitch = math.clamp(fpPitch - delta.Y * FREECAM_SENS * 0.022, math.rad(-89), math.rad(89))
                local rotation = CFrame.Angles(0, fpYaw, 0) * CFrame.Angles(fpPitch, 0, 0)
                Camera.CFrame = CFrame.new(head.Position) * rotation
                for _, part in ipairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then part.LocalTransparencyModifier = 1 end
                end
            end
        end)
    end

    updateCardVisuals()
    updateSpectateBar()
    updateStatus("Spectating " .. player.DisplayName .. " (" .. mode .. ")")
end

local function cycleSpectate(dir)
    local others = getSortedOthers()
    if #others == 0 then return end
    local idx = 1
    for i, p in ipairs(others) do
        if p == spectateTarget then idx = i break end
    end
    idx = ((idx - 1 + dir) % #others) + 1
    startSpectating(others[idx], spectateMode)
end

--=========================================================
-- FREECAM
--=========================================================
local function stopFreecam()
    freecamActive = false
    if freecamConn then freecamConn:Disconnect(); freecamConn = nil end
    if scrollConn then scrollConn:Disconnect(); scrollConn = nil end

    UIS.MouseBehavior = Enum.MouseBehavior.Default
    UIS.MouseIconEnabled = true
    Camera.CameraType = Enum.CameraType.Custom
    Camera.FieldOfView = 70

    local char = LocalPlayer.Character
    if char then
        Camera.CameraSubject = char:FindFirstChildOfClass("Humanoid") or char:FindFirstChild("HumanoidRootPart")
    end
    unfreezeCharacter()

    FreecamBtn.Text = "Enter Freecam"
    FreecamBtn:FindFirstChildOfClass("UIGradient").Color = gelSeq(COLORS.greenTop, COLORS.greenMid, COLORS.greenBot)
    KeybindFrame.Visible = false
    updateStatus("Ready")
end

local function startFreecam()
    if spectating then stopSpectating() end

    freecamActive = true
    freecamPos = Camera.CFrame.Position
    freecamVelocity = Vector3.new(0, 0, 0)

    local rx, ry = Camera.CFrame:ToEulerAnglesYXZ()
    freecamPitch, freecamTargetPitch = rx, rx
    freecamYaw, freecamTargetYaw = ry, ry
    freecamFOV, freecamTargetFOV = settings.freecamFOV, settings.freecamFOV

    Camera.CameraType = Enum.CameraType.Scriptable
    task.defer(function()
        UIS.MouseBehavior = Enum.MouseBehavior.LockCenter
        UIS.MouseIconEnabled = false
    end)

    freezeCharacter()
    FreecamBtn.Text = "Exit Freecam"
    FreecamBtn:FindFirstChildOfClass("UIGradient").Color = gelSeq(COLORS.redTop, COLORS.redMid, COLORS.redBot)
    KeybindFrame.Visible = true
    updateStatus("Freecam active")

    scrollConn = UIS.InputChanged:Connect(function(input)
        if not freecamActive then return end
        if input.UserInputType == Enum.UserInputType.MouseWheel then
            freecamTargetFOV = math.clamp(freecamTargetFOV - (input.Position.Z * FREECAM_ZOOM_SPEED), 15, 120)
        end
    end)

    freecamConn = RunService.RenderStepped:Connect(function(dt)
        if not freecamActive then return end

        local delta = UIS:GetMouseDelta()
        freecamTargetYaw = freecamTargetYaw - delta.X * FREECAM_SENS * 0.022
        freecamTargetPitch = math.clamp(freecamTargetPitch - delta.Y * FREECAM_SENS * 0.022, math.rad(-89), math.rad(89))

        local lerpFactor = 1 - math.exp(-LERP_ROT * dt)
        freecamYaw = freecamYaw + (freecamTargetYaw - freecamYaw) * lerpFactor
        freecamPitch = freecamPitch + (freecamTargetPitch - freecamPitch) * lerpFactor

        local rotation = CFrame.Angles(0, freecamYaw, 0) * CFrame.Angles(freecamPitch, 0, 0)
        local moveDir = Vector3.new(0, 0, 0)
        local speed = settings.freecamSpeed

        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) or UIS:IsKeyDown(Enum.KeyCode.RightShift) then
            speed = speed * FREECAM_SHIFT_MULT
        end
        if UIS:IsKeyDown(Enum.KeyCode.W) then moveDir += Vector3.new(0, 0, -1) end
        if UIS:IsKeyDown(Enum.KeyCode.S) then moveDir += Vector3.new(0, 0,  1) end
        if UIS:IsKeyDown(Enum.KeyCode.A) then moveDir += Vector3.new(-1, 0, 0) end
        if UIS:IsKeyDown(Enum.KeyCode.D) then moveDir += Vector3.new(1,  0, 0) end
        if UIS:IsKeyDown(Enum.KeyCode.E) or UIS:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0, 1, 0) end
        if UIS:IsKeyDown(Enum.KeyCode.Q) then moveDir += Vector3.new(0, -1, 0) end

        local targetVelocity = Vector3.new(0, 0, 0)
        if moveDir.Magnitude > 0 then
            local worldDir = CFrame.Angles(0, freecamYaw, 0):VectorToWorldSpace(moveDir.Unit)
            targetVelocity = worldDir * speed
        end

        freecamVelocity = freecamVelocity:Lerp(targetVelocity, 1 - math.exp(-MOMENTUM_DECAY * dt))
        freecamPos = freecamPos + freecamVelocity * dt

        Camera.CFrame = CFrame.new(freecamPos) * rotation
        freecamFOV = freecamFOV + (freecamTargetFOV - freecamFOV) * (1 - math.exp(-LERP_FOV * dt))
        Camera.FieldOfView = freecamFOV
    end)
end

