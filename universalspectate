	Avatar.Parent = Card

	local avatarCorner = Instance.new("UICorner")
	avatarCorner.CornerRadius = UDim.new(0, 22)
	avatarCorner.Parent = Avatar

	task.spawn(function()
		local url = getThumb(player.UserId)
		if Avatar and Avatar.Parent then Avatar.Image = url end
	end)

	local NameBlock = Instance.new("Frame")
	NameBlock.Size = UDim2.new(0, GUI_WIDTH - 44 - 90, 1, 0)
