local function getSortedOthers()
    local others = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then others[#others + 1] = p end
    end
    table.sort(others, function(a, b) return a.UserId < b.UserId end)
    return others
end

