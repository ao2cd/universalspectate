local activeSlider = nil
local function makeSlider(labelText, minV, maxV, default, suffix, order, onChange)
    local wrap = Instance.new("Frame")
    wrap.Size = UDim2.new(1, 0, 0, 44)
    wrap.BackgroundTransparency = 1
    wrap.ZIndex = 6
    wrap.LayoutOrder = order
    wrap.Parent = SettingsPanel

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, 0, 0, 18)
    lbl.BackgroundTransparency = 1
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 6
    lbl.Text = labelText .. ": " .. tostring(default) .. (suffix or "")
    style(lbl, 14, "semi", COLORS.text)
    lbl.Parent = wrap

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1, 0, 0, 12)
    track.Position = UDim2.new(0, 0, 0, 24)
    track.BackgroundColor3 = COLORS.inputBg
    track.ZIndex = 6
    track.Parent = wrap
    corner(track, 6)
    stroke(track, COLORS.inputStk, 1, 0.2)

    local fill = Instance.new("Frame")
    fill.BackgroundColor3 = Color3.new(1,1,1)
    fill.ZIndex = 6
    fill.Parent = track
    corner(fill, 6)
    grad(fill, ColorSequence.new(COLORS.blueTop, COLORS.blueBot), 90)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new(0, 0, 0.5, 0)
    knob.BackgroundColor3 = Color3.new(1,1,1)
    knob.ZIndex = 7
    knob.Parent = track
    corner(knob, 999)
    stroke(knob, COLORS.blueStk, 1, 0.1)

    local value = default
    local function setFraction(f)
        f = math.clamp(f, 0, 1)
        value = math.floor(minV + (maxV - minV) * f + 0.5)
        fill.Size = UDim2.new(f, 0, 1, 0)
        knob.Position = UDim2.new(f, 0, 0.5, 0)
        lbl.Text = labelText .. ": " .. tostring(value) .. (suffix or "")
        if onChange then onChange(value) end
    end
    setFraction((default - minV) / (maxV - minV))

    local function updateFromX(px)
        local rel = (px - track.AbsolutePosition.X) / track.AbsoluteSize.X
        setFraction(rel)
    end

    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            activeSlider = updateFromX
            updateFromX(input.Position.X)
        end
    end)
end

