            local q = string.lower(searchQuery)
            local matches = string.find(string.lower(pl.Name), q, 1, true)
                or string.find(string.lower(pl.DisplayName), q, 1, true)
            card.Visible = (searchQuery == "" or matches) and true or false
        end
    end
end

