--=========================================================
-- BUBBLE SYSTEM (one Heartbeat drives them all)
--=========================================================
local allBubbles = {}

local function resetBubble(s)
    local cw = math.max(40, s.container.AbsoluteSize.X)
    local ch = math.max(60, s.container.AbsoluteSize.Y)
    s.size     = math.random(6, 16)
    s.baseX    = math.random(4, math.max(5, cw - 4))
    s.y        = ch + s.size + math.random(0, 50)   -- center-y, starts below
    s.speed    = math.random(14, 42)                -- px/sec upward
    s.amp      = math.random(4, 16)                 -- sway amplitude
    s.freq     = math.random(3, 10) / 10            -- sway frequency
    s.phase    = math.random() * 10
    s.baseTrans = math.random(52, 78) / 100
    s.f.Size   = UDim2.fromOffset(s.size, s.size)
end

local function addBubbles(container, count, zindex)
    container.ClipsDescendants = true
    for _ = 1, count do
        local b = Instance.new("Frame")
        b.AnchorPoint = Vector2.new(0.5, 0.5)
        b.BackgroundColor3 = COLORS.bubble
        b.BackgroundTransparency = 0.7
        b.BorderSizePixel = 0
        b.ZIndex = zindex or 1
        b.Parent = container
        corner(b, 999)
        stroke(b, Color3.fromRGB(220, 245, 255), 1, 0.55)

        local s = { f = b, container = container }
        resetBubble(s)
        table.insert(allBubbles, s)
    end
end

RunService.Heartbeat:Connect(function(dt)
    for _, s in ipairs(allBubbles) do
        local f = s.f
        if not f.Parent then continue end
        if not settings.bubbles then
            f.Visible = false
            continue
        end
        f.Visible = true

        s.y = s.y - s.speed * dt
        s.phase = s.phase + s.freq * dt
        local ch = math.max(60, s.container.AbsoluteSize.Y)
        if s.y < -s.size then
            resetBubble(s)
            ch = math.max(60, s.container.AbsoluteSize.Y)
        end

        local swayX = math.sin(s.phase * math.pi * 2) * s.amp
        local pulse = 1 + math.sin(s.phase * math.pi) * 0.12
        local drawSize = s.size * pulse
        local frac = math.clamp(s.y / ch, 0, 1)

        f.Size = UDim2.fromOffset(drawSize, drawSize)
        f.Position = UDim2.fromOffset(s.baseX + swayX, s.y)
        f.BackgroundTransparency = s.baseTrans + (1 - frac) * 0.18
    end
end)

