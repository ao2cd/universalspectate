--=========================================================
-- HELPERS
--=========================================================
local function corner(obj, r)
    local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r); c.Parent = obj; return c
end

local function stroke(obj, color, thick, trans)
    local s = Instance.new("UIStroke")
    s.Color = color or Color3.new(1,1,1)
    s.Thickness = thick or 1
    s.Transparency = trans or 0
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = obj
    return s
end

local function grad(obj, seq, rotation)
    local g = Instance.new("UIGradient")
    g.Color = seq
    g.Rotation = rotation or 90
    g.Parent = obj
    return g
end

local function style(obj, size, weight, color)
    obj.Font = (weight == "bold" and Enum.Font.SourceSansBold)
        or (weight == "semi" and Enum.Font.SourceSansSemibold)
        or Enum.Font.SourceSans
    obj.TextSize = size or 15
    obj.TextColor3 = color or COLORS.text
end

-- Two-band gloss gradient (the glossy "gel" look)
local function gelSeq(topC, midC, botC)
    return ColorSequence.new({
        ColorSequenceKeypoint.new(0.00, topC),
        ColorSequenceKeypoint.new(0.48, midC),
        ColorSequenceKeypoint.new(0.52, midC),
        ColorSequenceKeypoint.new(1.00, botC),
    })
end

local function gel(btn, topC, midC, botC, strokeC)
    btn.BackgroundColor3 = Color3.new(1,1,1)
    grad(btn, gelSeq(topC, midC, botC), 90)
    stroke(btn, strokeC, 1, 0.15)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.TextStrokeTransparency = 0.5
    btn.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    btn.AutoButtonColor = false
end

